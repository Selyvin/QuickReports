---
const solutions = [
  {
    icon: '🧾',
    title: 'Unpaid Invoices Dashboard',
    description: 'See every open invoice by age, customer, and amount without digging through QBO reports. Send reminders directly from the view.',
    href: '#',
  },
  {
    icon: '📦',
    title: 'Vendor Spend by Category',
    description: 'Break down all your bill payments by vendor and category. Spot where money is going before month-end.',
    href: '#',
  },
  {
    icon: '📅',
    title: 'Bills Due This Week',
    description: 'A focused list of what needs to be paid — sorted by due date, with aging flags for anything already late.',
    href: '#',
  },
  {
    icon: '⚠️',
    title: 'Reconciliation Exceptions',
    description: "Surface transactions that don't reconcile cleanly. Catch mismatches between your bank feed and QBO before they compound.",
    href: '#',
  },
  {
    icon: '📊',
    title: 'Profit by Customer',
    description: 'See revenue, cost of goods, and gross margin broken down per customer — pulled directly from your QBO data.',
    href: '#',
  },
  {
    icon: '📎',
    title: 'Missing Transaction Attachments',
    description: 'Find all expenses without receipts in one scan. Keep your books audit-ready without hunting through individual transactions.',
    href: '#',
  },
];

const qbCons = [
  'Build a report, then customize it',
  'Mixed screens for different tasks',
  'No clear aging view out of the box',
  'Hard to share one focused view safely',
];

const ourPros = [
  'Open the workflow directly',
  'One screen per task',
  'Aging, totals, and alerts at a glance',
  'Shareable links to focused views',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>KeeprKit — A faster, cleaner way to work with QuickBooks data</title>
    <meta name="description" content="KeeprKit connects to QuickBooks Online and turns slow navigation into focused workflows. Unpaid invoices, vendor spend, bills due, and more — in one clean view." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      @import "tailwindcss";
      * { font-family: 'Inter', system-ui, sans-serif; }
    </style>
  </head>

  <body class="bg-white text-gray-900 antialiased">

    <!-- ── Header ──────────────────────────────────────────── -->
    <header class="sticky top-0 z-50 border-b border-gray-200 bg-white">
      <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-6">
        <a href="/" class="flex items-center gap-2.5 text-gray-900 no-underline">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-green-600">
            <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <span class="text-base font-bold">KeeprKit</span>
        </a>
        <nav class="flex items-center gap-1">
          <a href="#solutions" class="rounded-md px-3 py-1.5 text-sm font-medium text-gray-500 transition hover:bg-gray-100 hover:text-gray-900">Solutions</a>
          <a href="#demo" class="rounded-md px-3 py-1.5 text-sm font-medium text-gray-500 transition hover:bg-gray-100 hover:text-gray-900">Demo</a>
          <a href="#faq" class="rounded-md px-3 py-1.5 text-sm font-medium text-gray-500 transition hover:bg-gray-100 hover:text-gray-900">FAQ</a>
          <a href="#demo" class="ml-2 rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-green-700">Try demo</a>
        </nav>
      </div>
    </header>

    <!-- ── Hero ────────────────────────────────────────────── -->
    <section class="border-b border-gray-100 bg-white px-6 py-12 lg:py-16">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-[1fr_1.2fr] lg:gap-14">

          <!-- Left: copy -->
          <div class="pt-2">
            <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">
              <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
              Connects to QuickBooks Online
            </div>
            <h1 class="mb-4 text-[2.6rem] font-extrabold leading-[1.1] tracking-tight text-gray-900">
              QuickBooks, the way it should work.
            </h1>
            <p class="mb-7 text-base leading-relaxed text-gray-500">
              No ads, no offers, no glitches
            </p>
            <div class="flex flex-wrap items-center gap-4">
              <a href="#demo" class="rounded-lg bg-green-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-green-700">
                Try interactive demo
              </a>
              <a href="#solutions" class="text-sm font-semibold text-gray-500 transition hover:text-gray-900">
                Browse solutions →
              </a>
            </div>
            <p class="mt-5 text-xs text-gray-400">No migration required · Sandbox demo available · Works with your existing QBO account</p>
          </div>

          <!-- Right: product preview -->
          <div class="w-full">
            <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-md">

              <!-- Window chrome + workflow tabs -->
              <div class="border-b border-gray-100 bg-gray-50 px-4 pt-3">
                <div class="mb-3 flex items-center gap-1.5">
                  <span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
                </div>
                <!-- Tabs -->
                <div class="flex gap-0 text-xs font-medium">
                  <div class="border-b-2 border-green-600 px-4 pb-2.5 text-green-700">Unpaid Invoices</div>
                  <div class="px-4 pb-2.5 text-gray-400 hover:text-gray-600">Vendor Spend</div>
                  <div class="px-4 pb-2.5 text-gray-400 hover:text-gray-600">Bills Due</div>
                </div>
              </div>

              <!-- View header -->
              <div class="flex items-center justify-between border-b border-gray-100 px-5 py-3">
                <div>
                  <p class="text-sm font-semibold text-gray-900">Unpaid Invoices</p>
                  <p class="text-xs text-gray-400">April 2026 · 14 open</p>
                </div>
                <div class="flex items-center gap-2">
                  <span class="rounded-full bg-red-50 px-2.5 py-1 text-xs font-semibold text-red-600">4 Overdue</span>
                  <button class="rounded-md border border-gray-200 px-2.5 py-1 text-xs font-medium text-gray-500 hover:bg-gray-50">Export</button>
                  <button class="rounded-md bg-green-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-green-700">Send reminders</button>
                </div>
              </div>

              <!-- Summary stats row -->
              <div class="grid grid-cols-3 divide-x divide-gray-100 border-b border-gray-100">
                <div class="px-5 py-3">
                  <p class="text-lg font-extrabold text-red-500">$6,050</p>
                  <p class="text-xs text-gray-400">Overdue</p>
                </div>
                <div class="px-5 py-3">
                  <p class="text-lg font-extrabold text-yellow-500">$4,025</p>
                  <p class="text-xs text-gray-400">Due this week</p>
                </div>
                <div class="px-5 py-3">
                  <p class="text-lg font-extrabold text-gray-700">$10,075</p>
                  <p class="text-xs text-gray-400">Total outstanding</p>
                </div>
              </div>

              <!-- Invoice table -->
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-100 bg-gray-50">
                    <th class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Customer</th>
                    <th class="px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Invoice</th>
                    <th class="px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Due date</th>
                    <th class="px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-gray-400">Amount</th>
                    <th class="px-5 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-gray-400">Aging</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  <tr class="hover:bg-gray-50">
                    <td class="px-5 py-3 font-medium text-gray-900">Acme Corporation</td>
                    <td class="px-3 py-3 text-gray-400">#1042</td>
                    <td class="px-3 py-3 text-gray-500">Mar 15</td>
                    <td class="px-3 py-3 text-right font-semibold text-red-500">$4,200</td>
                    <td class="px-5 py-3 text-right"><span class="rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-500">32 days</span></td>
                  </tr>
                  <tr class="hover:bg-gray-50">
                    <td class="px-5 py-3 font-medium text-gray-900">Sunrise Media</td>
                    <td class="px-3 py-3 text-gray-400">#1038</td>
                    <td class="px-3 py-3 text-gray-500">Mar 28</td>
                    <td class="px-3 py-3 text-right font-semibold text-red-500">$1,850</td>
                    <td class="px-5 py-3 text-right"><span class="rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-500">19 days</span></td>
                  </tr>
                  <tr class="hover:bg-gray-50">
                    <td class="px-5 py-3 font-medium text-gray-900">Holloway LLC</td>
                    <td class="px-3 py-3 text-gray-400">#1051</td>
                    <td class="px-3 py-3 text-gray-500">Apr 5</td>
                    <td class="px-3 py-3 text-right text-gray-700">$3,100</td>
                    <td class="px-5 py-3 text-right"><span class="rounded-full bg-yellow-50 px-2.5 py-0.5 text-xs font-semibold text-yellow-600">11 days</span></td>
                  </tr>
                  <tr class="hover:bg-gray-50">
                    <td class="px-5 py-3 font-medium text-gray-900">Vantage Group</td>
                    <td class="px-3 py-3 text-gray-400">#1056</td>
                    <td class="px-3 py-3 text-gray-500">Apr 18</td>
                    <td class="px-3 py-3 text-right text-gray-500">$925</td>
                    <td class="px-5 py-3 text-right"><span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-semibold text-gray-500">Due in 2d</span></td>
                  </tr>
                  <tr class="hover:bg-gray-50">
                    <td class="px-5 py-3 font-medium text-gray-900">Peak Strategies</td>
                    <td class="px-3 py-3 text-gray-400">#1058</td>
                    <td class="px-3 py-3 text-gray-500">Apr 21</td>
                    <td class="px-3 py-3 text-right text-gray-500">$6,400</td>
                    <td class="px-5 py-3 text-right"><span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-semibold text-gray-500">Due in 5d</span></td>
                  </tr>
                </tbody>
              </table>

            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Solutions ────────────────────────────────────────── -->
    <section class="border-b border-gray-100 bg-gray-50 px-6 py-14" id="solutions">
      <div class="mx-auto max-w-7xl">
        <div class="mb-8">
          <p class="mb-2 text-xs font-bold uppercase tracking-widest text-green-600">Solutions</p>
          <h2 class="mb-2 text-2xl font-extrabold text-gray-900">Focused screens for the QBO tasks you repeat most</h2>
          <p class="text-sm text-gray-500">Each workflow opens as its own focused view — no digging through reports, no rebuilding filters, no starting from scratch.</p>
        </div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {solutions.map((sol) => (
            <a href={sol.href} class="flex flex-col gap-2 rounded-lg border border-gray-200 bg-white p-5 no-underline transition hover:border-gray-300 hover:shadow-sm">
              <h3 class="text-sm font-semibold text-gray-900">{sol.title}</h3>
              <p class="flex-1 text-sm leading-relaxed text-gray-500">{sol.description}</p>
              <span class="text-xs font-semibold text-green-600">View solution →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Demo ──────────────────────────────────────────────── -->
    <section class="border-b border-gray-100 bg-white px-6 py-14" id="demo">
      <div class="mx-auto max-w-7xl">
        <div class="mb-7">
          <p class="mb-2 text-xs font-bold uppercase tracking-widest text-green-600">Interactive demo</p>
          <h2 class="mb-2 text-2xl font-extrabold text-gray-900">Try the product with sandbox data</h2>
          <p class="text-sm text-gray-500">No login required. Explore a realistic sample workspace before connecting QuickBooks.</p>
        </div>

        <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
          <!-- Workflow tabs toolbar -->
          <div class="flex flex-wrap items-center gap-1.5 border-b border-gray-100 bg-gray-50 px-4 py-2.5">
            <button class="rounded-md border border-green-200 bg-green-50 px-3 py-1.5 text-xs font-semibold text-green-700">Unpaid Invoices</button>
            <button class="rounded-md border border-transparent px-3 py-1.5 text-xs font-medium text-gray-500 hover:bg-gray-100">Bills Due</button>
            <button class="rounded-md border border-transparent px-3 py-1.5 text-xs font-medium text-gray-500 hover:bg-gray-100">Vendor Spend</button>
            <button class="rounded-md border border-transparent px-3 py-1.5 text-xs font-medium text-gray-500 hover:bg-gray-100">Reconciliation</button>
            <div class="ml-auto flex gap-2">
              <button class="rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-50">Export CSV</button>
              <button class="rounded-md bg-green-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-green-700">Send reminders</button>
            </div>
          </div>

          <!-- KPI strip -->
          <div class="grid grid-cols-2 divide-x divide-gray-100 border-b border-gray-100 sm:grid-cols-4">
            <div class="px-5 py-3">
              <p class="text-lg font-extrabold text-red-500">$18,340</p>
              <p class="text-xs text-gray-400">Overdue · 7 invoices</p>
            </div>
            <div class="px-5 py-3">
              <p class="text-lg font-extrabold text-yellow-500">$11,200</p>
              <p class="text-xs text-gray-400">Due within 14 days</p>
            </div>
            <div class="px-5 py-3">
              <p class="text-lg font-extrabold text-gray-700">$43,815</p>
              <p class="text-xs text-gray-400">Total outstanding</p>
            </div>
            <div class="px-5 py-3">
              <p class="text-lg font-extrabold text-gray-400">14</p>
              <p class="text-xs text-gray-400">Open invoices</p>
            </div>
          </div>

          <!-- Table -->
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Customer</th>
                  <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Invoice</th>
                  <th class="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">Due date</th>
                  <th class="px-4 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-gray-400">Amount</th>
                  <th class="px-4 py-2.5 text-center text-xs font-semibold uppercase tracking-wide text-gray-400">Aging</th>
                  <th class="px-5 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-gray-400">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <tr class="bg-blue-50/40">
                  <td class="px-5 py-3 font-medium text-gray-900">Acme Corporation</td>
                  <td class="px-4 py-3 text-gray-400">#1042</td>
                  <td class="px-4 py-3 text-gray-500">Mar 15</td>
                  <td class="px-4 py-3 text-right font-semibold text-red-500">$4,200</td>
                  <td class="px-4 py-3 text-center"><span class="rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-500">32 days</span></td>
                  <td class="px-5 py-3 text-right"><button class="text-xs font-semibold text-green-600 hover:text-green-800">Send reminder</button></td>
                </tr>
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3 font-medium text-gray-900">Sunrise Media</td>
                  <td class="px-4 py-3 text-gray-400">#1038</td>
                  <td class="px-4 py-3 text-gray-500">Mar 28</td>
                  <td class="px-4 py-3 text-right font-semibold text-red-500">$1,850</td>
                  <td class="px-4 py-3 text-center"><span class="rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-semibold text-red-500">19 days</span></td>
                  <td class="px-5 py-3 text-right"><button class="text-xs font-semibold text-green-600 hover:text-green-800">Send reminder</button></td>
                </tr>
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3 font-medium text-gray-900">Holloway LLC</td>
                  <td class="px-4 py-3 text-gray-400">#1051</td>
                  <td class="px-4 py-3 text-gray-500">Apr 5</td>
                  <td class="px-4 py-3 text-right text-gray-700">$3,100</td>
                  <td class="px-4 py-3 text-center"><span class="rounded-full bg-yellow-50 px-2.5 py-0.5 text-xs font-semibold text-yellow-600">11 days</span></td>
                  <td class="px-5 py-3 text-right"><button class="text-xs font-semibold text-green-600 hover:text-green-800">Send reminder</button></td>
                </tr>
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3 font-medium text-gray-900">Vantage Group</td>
                  <td class="px-4 py-3 text-gray-400">#1056</td>
                  <td class="px-4 py-3 text-gray-500">Apr 18</td>
                  <td class="px-4 py-3 text-right text-gray-500">$925</td>
                  <td class="px-4 py-3 text-center"><span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-semibold text-gray-500">Due in 2d</span></td>
                  <td class="px-5 py-3 text-right"><button class="text-xs text-gray-400 hover:text-gray-600">View invoice</button></td>
                </tr>
                <tr class="hover:bg-gray-50">
                  <td class="px-5 py-3 font-medium text-gray-900">Peak Strategies</td>
                  <td class="px-4 py-3 text-gray-400">#1058</td>
                  <td class="px-4 py-3 text-gray-500">Apr 21</td>
                  <td class="px-4 py-3 text-right text-gray-500">$6,400</td>
                  <td class="px-4 py-3 text-center"><span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-semibold text-gray-500">Due in 5d</span></td>
                  <td class="px-5 py-3 text-right"><button class="text-xs text-gray-400 hover:text-gray-600">View invoice</button></td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Demo CTAs -->
          <div class="flex flex-wrap items-center gap-3 border-t border-gray-100 px-5 py-4">
            <a href="#" class="rounded-lg bg-green-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-700">Open full demo</a>
            <a href="#" class="text-sm font-semibold text-gray-500 hover:text-gray-900">Connect QuickBooks →</a>
            <p class="ml-auto text-xs text-gray-400">Sandbox data only — your QuickBooks account stays untouched until you connect.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Comparison ────────────────────────────────────────── -->
    <section class="border-b border-gray-100 bg-gray-50 px-6 py-14">
      <div class="mx-auto max-w-7xl">
        <div class="mb-8">
          <p class="mb-2 text-xs font-bold uppercase tracking-widest text-green-600">Why KeepKit</p>
          <h2 class="mb-2 text-2xl font-extrabold text-gray-900">Keep QuickBooks as the source of truth. Use KeepKit for the day-to-day workflow.</h2>
          <p class="max-w-xl text-sm text-gray-500">QuickBooks is excellent accounting software. KeepKit adds a faster, more focused layer for the operational tasks you check every day.</p>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:max-w-3xl">
          <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
            <div class="border-b border-gray-100 bg-gray-50 px-4 py-3 text-xs font-semibold uppercase tracking-wide text-gray-500">QuickBooks Online</div>
            <ul class="divide-y divide-gray-50 px-4 py-2">
              {qbCons.map((item) => (
                <li class="flex items-center gap-2.5 py-2.5 text-sm text-gray-500">
                  <span class="font-bold text-red-400 shrink-0">✗</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="overflow-hidden rounded-lg border border-green-200 bg-white shadow-sm">
            <div class="border-b border-green-100 bg-green-50 px-4 py-3 text-xs font-semibold uppercase tracking-wide text-green-700">KeepKit</div>
            <ul class="divide-y divide-gray-50 px-4 py-2">
              {ourPros.map((item) => (
                <li class="flex items-center gap-2.5 py-2.5 text-sm text-gray-700">
                  <span class="font-bold text-green-600 shrink-0">✓</span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Final CTA ──────────────────────────────────────────── -->
    <section class="bg-gray-900 px-6 py-16 text-center">
      <div class="mx-auto max-w-xl">
        <h2 class="mb-4 text-2xl font-extrabold text-white lg:text-3xl">
          Stop navigating QuickBooks.<br />Start working with your data.
        </h2>
        <p class="mx-auto mb-8 text-sm text-gray-400">
          Connect your QuickBooks account and get focused views of your most important workflows in under two minutes.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="#demo" class="rounded-lg bg-green-600 px-7 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-green-500">
            Try interactive demo
          </a>
          <a href="#solutions" class="rounded-lg border border-gray-600 px-7 py-3 text-sm font-semibold text-gray-300 transition hover:border-gray-400 hover:text-white">
            Browse solutions
          </a>
        </div>
        <p class="mt-5 text-xs text-gray-600">No migration required · Sandbox demo available · Works with your existing QBO account</p>
      </div>
